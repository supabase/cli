{
  "name": "@supabase/cli-test-helpers",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "test": "nx run-many -t test:unit --projects=$npm_package_name",
    "check:all": "nx run-many -t types:check lint:check fmt:check knip:check --projects=$npm_package_name",
    "fix:all": "nx run-many -t lint:fix fmt:fix knip:fix --projects=$npm_package_name"
  },
  "devDependencies": {
    "@tsconfig/bun": "catalog:",
    "@types/bun": "catalog:",
    "@typescript/native-preview": "catalog:",
    "@vitest/coverage-istanbul": "catalog:",
    "knip": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "vitest": "catalog:"
  },
  "knip": {
    "entry": [
      "src/**/*.test.ts"
    ],
    "ignoreDependencies": [
      "@typescript/native-preview",
      "oxfmt",
      "oxlint",
      "oxlint-tsgolint"
    ],
    "ignoreBinaries": [
      "nx"
    ]
  }
}
