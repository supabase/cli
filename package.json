{
  "name": "@supabase/root",
  "private": true,
  "workspaces": {
    "packages": [
      "packages/*",
      "apps/*"
    ],
    "catalog": {
      "@effect/atom-react": "^4.0.0-beta.40",
      "@effect/platform-bun": "^4.0.0-beta.40",
      "@effect/platform-node": "^4.0.0-beta.40",
      "@effect/vitest": "^4.0.0-beta.40",
      "@tsconfig/bun": "^1.0.10",
      "@types/bun": "^1.3.11",
      "@typescript/native-preview": "^7.0.0-dev.20260325.1",
      "knip": "^5.88.1",
      "oxfmt": "^0.42.0",
      "oxlint": "^1.57.0",
      "oxlint-tsgolint": "^0.17.3",
      "effect": "^4.0.0-beta.40",
      "@vitest/coverage-istanbul": "^4.1.1",
      "vitest": "^4.1.1"
    }
  },
  "scripts": {
    "check": "bun run --workspaces --parallel \"*:check\"",
    "repos:install": "git submodule update --init --recursive",
    "repos:pull": "git submodule update --remote"
